# AI-Assisted: True
# AI-Provider: Anthropic
# AI-Model: claude-sonnet-4-6
# AI-Human-Reviewed: True

FROM quay.io/fedora/fedora-toolbox:43

# CUDA environment (libraries injected from host via nvidia-container-toolkit)
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility
ENV PATH=/usr/local/cuda/bin:${PATH}
ENV LD_LIBRARY_PATH=/usr/local/cuda/lib64:${LD_LIBRARY_PATH}

# Add NVIDIA CUDA repo
RUN curl https://developer.download.nvidia.com/compute/cuda/repos/fedora43/x86_64/cuda-fedora43.repo > /etc/yum.repos.d/cuda.repo

# Install toolbox-expected packages + vim
RUN dnf install -y \
    vim \
    sudo \
    passwd \
    util-linux \
    userspace-rcu \
    cuda-toolkit \
    && dnf clean all
